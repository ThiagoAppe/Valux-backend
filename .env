# =========================
# APP
# =========================
APP_ENV=development
APP_NAME=valux
DEBUG=true

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql+psycopg://valux-dev:valux-dev@172.24.121.223:5432/valux

# Pool tuning (opcional pero útil)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true

# =========================
# AUTH
# =========================
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# INVENTORY / BUSINESS RULES
# =========================
DEFAULT_STOCK_RESERVATION_MINUTES=15
ALLOW_NEGATIVE_STOCK=false

# =========================
# PAYMENT (ej: Mercado Pago)
# =========================
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# =========================
# EMAIL (WIP)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASSWORD=your_password

# =========================
# LOGGING
# =========================
LOG_LEVEL=info

# =========================
# MEDIA URL
# =========================
MEDIA_BASE_URL=http://localhost:8000/static/